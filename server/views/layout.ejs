<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> - Synth Monitor</title>
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <header>
    <div class="nav-inner">
      <a href="/dashboard" class="nav-brand" data-testid="nav-brand">Synth Monitor</a>
      <% if (user) { %>
        <nav class="nav-links">
          <a href="/dashboard" data-testid="nav-dashboard">Dashboard</a>
          <a href="/products" data-testid="nav-products">Products</a>
          <a href="/cart" class="cart-link" data-testid="nav-cart">
            Cart
            <% if (cartCount > 0) { %>
              <span class="badge" data-testid="cart-badge"><%= cartCount %></span>
            <% } %>
          </a>
          <a href="/profile" data-testid="nav-profile">Profile</a>
          <a href="/settings" data-testid="nav-settings">Settings</a>
          <a href="/observability" data-testid="nav-observability">Observability</a>
          <a href="/logout" data-testid="nav-logout">Logout</a>
        </nav>
      <% } %>
    </div>
  </header>
  <main class="container">
    <%- body %>
  </main>
</body>
</html>
