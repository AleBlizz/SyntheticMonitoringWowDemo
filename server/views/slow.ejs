<div class="slow-page">
  <h1 data-testid="slow-heading">Slow Page</h1>
  <div class="timer">&#9203;</div>
  <p data-testid="slow-message">This page was intentionally delayed by <%= delay %>ms</p>
  <p data-testid="slow-timestamp" style="margin-top:1rem;color:var(--text-muted)">Loaded at: <%= new Date().toISOString() %></p>
</div>
