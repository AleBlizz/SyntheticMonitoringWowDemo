<div class="login-container">
  <div class="card">
    <h1 data-testid="login-heading">Login</h1>
    <% if (error) { %>
      <div class="error-message" data-testid="login-error"><%= error %></div>
    <% } %>
    <form data-testid="login-form" method="POST" action="/login">
      <div class="form-group">
        <label for="username">Username</label>
        <input data-testid="username-input" type="text" id="username" name="username" placeholder="Username" required>
      </div>
      <div class="form-group">
        <label for="password">Password</label>
        <input data-testid="password-input" type="password" id="password" name="password" placeholder="Password" required>
      </div>
      <button data-testid="login-button" type="submit" class="btn btn-primary" style="width:100%">Login</button>
    </form>
  </div>
</div>
